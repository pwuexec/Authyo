@page "/"
@inject IDispatcher Dispatcher
@inject IAdminContext AdminContext
@using Authy.Application.Domain.Organizations

<PageTitle>Dashboard - Authy</PageTitle>

<div class="mb-4">
    <h1>Dashboard</h1>
    <p class="text-secondary">Manage your identity and access management system.</p>
</div>

@if (isLoading)
{
    <LoadingSpinner IsLoading="true" Message="Loading statistics..." />
}
else
{
    <div class="stats-grid">
        @if (AdminContext.IsRootUser)
        {
            <div class="stat-card">
                <span class="stat-label">Organizations</span>
                <div class="stat-value">@organizationCount</div>
                <a href="/organizations" class="btn btn-sm btn-secondary w-full mt-2">Manage</a>
            </div>
        }

        <div class="stat-card">
            <span class="stat-label">Roles</span>
            <div class="stat-value">-</div>
            <a href="/roles" class="btn btn-sm btn-secondary w-full mt-2">Manage</a>
        </div>

        <div class="stat-card">
            <span class="stat-label">Scopes</span>
            <div class="stat-value">-</div>
            <a href="/scopes" class="btn btn-sm btn-secondary w-full mt-2">Manage</a>
        </div>

        <div class="stat-card">
            <span class="stat-label">Sessions</span>
            <div class="stat-value">-</div>
            <a href="/sessions" class="btn btn-sm btn-secondary w-full mt-2">View</a>
        </div>
    </div>

    <div class="quick-actions">
        <h2 class="mb-3">Quick Actions</h2>
        <div class="flex gap-2">
            @if (AdminContext.IsRootUser)
            {
                <a href="/organizations" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Organization
                </a>
            }
            <a href="/roles" class="btn btn-secondary">
                <i class="bi bi-plus-lg"></i> Role
            </a>
            <a href="/scopes" class="btn btn-secondary">
                <i class="bi bi-plus-lg"></i> Scope
            </a>
        </div>
    </div>

    @if (AdminContext.IsRootUser && organizations.Any())
    {
        <div class="recent-section">
            <div class="justify-between flex items-center mb-3">
                <h2 class="mb-0">Recent Organizations</h2>
                <a href="/organizations" class="btn btn-sm btn-secondary">View All</a>
            </div>
            <div class="table-container">
                <table class="simple-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>ID</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var org in organizations.Take(5))
                        {
                            <tr>
                                <td><span class="font-semibold text-primary">@org.Name</span></td>
                                <td><code class="text-muted small">@org.Id</code></td>
                                <td>
                                    <a href="/organizations/@org.Id" class="btn btn-sm btn-secondary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    private List<GetOrganizationsOutput> organizations = [];
    private int organizationCount = 0;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (AdminContext.IsRootUser)
        {
            var result = await Dispatcher.DispatchAsync(new GetOrganizationsQuery(), CancellationToken.None);
            if (result.IsSuccess)
            {
                organizations = result.Value;
                organizationCount = organizations.Count;
            }
        }
        isLoading = false;
    }
}
